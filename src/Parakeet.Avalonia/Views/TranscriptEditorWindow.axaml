<Window x:Class="ParakeetCSharp.Views.TranscriptEditorWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="using:ParakeetCSharp.Converters"
        xmlns:local="using:ParakeetCSharp"
        Title="{local:Loc editor_heading}"
        Width="1040" Height="820"
        MinWidth="820" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:BoolToVisibilityConverter x:Key="InvBoolToVis" Invert="True" />
        <conv:BoolToOpacityConverter x:Key="BoolToOpacity" />
        <conv:BoolToOpacityConverter x:Key="InvBoolToOpacity" Invert="True" />
        <SolidColorBrush x:Key="EditorPrimaryButtonBrush" Color="#3070C8" />
        <SolidColorBrush x:Key="EditorSecondaryButtonBrush" Color="#3A404A" />
        <SolidColorBrush x:Key="EditorDangerButtonBrush" Color="#C8404E" />
        <SolidColorBrush x:Key="EditorButtonTextBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="EditorButtonBorderBrush" Color="#45475A" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="{StaticResource EditorPrimaryButtonBrush}" />
            <Setter Property="Foreground" Value="{StaticResource EditorButtonTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource EditorButtonBorderBrush}" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Opacity" Value="0.85" />
            <Setter Property="Background" Value="{StaticResource EditorPrimaryButtonBrush}" />
        </Style>
        <Style Selector="Button:pressed">
            <Setter Property="Opacity" Value="0.70" />
            <Setter Property="Background" Value="{StaticResource EditorPrimaryButtonBrush}" />
        </Style>
        <Style Selector="Button.primary-button">
            <Setter Property="Background" Value="{StaticResource EditorPrimaryButtonBrush}" />
            <Setter Property="Foreground" Value="{StaticResource EditorButtonTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource EditorButtonBorderBrush}" />
        </Style>
        <Style Selector="Button.secondary-button">
            <Setter Property="Background" Value="{StaticResource EditorSecondaryButtonBrush}" />
            <Setter Property="Foreground" Value="{StaticResource EditorButtonTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource EditorButtonBorderBrush}" />
        </Style>
        <Style Selector="Button.secondary-button:pointerover">
            <Setter Property="Background" Value="{StaticResource EditorSecondaryButtonBrush}" />
        </Style>
        <Style Selector="Button.secondary-button:pressed">
            <Setter Property="Background" Value="{StaticResource EditorSecondaryButtonBrush}" />
        </Style>
        <Style Selector="Button.danger-button">
            <Setter Property="Background" Value="{StaticResource EditorDangerButtonBrush}" />
            <Setter Property="Foreground" Value="{StaticResource EditorButtonTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource EditorButtonBorderBrush}" />
        </Style>
        <Style Selector="Button.danger-button:pointerover">
            <Setter Property="Background" Value="{StaticResource EditorDangerButtonBrush}" />
        </Style>
        <Style Selector="Button.danger-button:pressed">
            <Setter Property="Background" Value="{StaticResource EditorDangerButtonBrush}" />
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="ComboBox:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="Button.action-button">
            <Setter Property="Background" Value="{StaticResource EditorPrimaryButtonBrush}" />
            <Setter Property="Foreground" Value="{StaticResource EditorButtonTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource EditorButtonBorderBrush}" />
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="26" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>
        <Style Selector="Button.action-button:pointerover">
            <Setter Property="Background" Value="{StaticResource EditorPrimaryButtonBrush}" />
        </Style>
        <Style Selector="Button.action-button:pressed">
            <Setter Property="Background" Value="{StaticResource EditorPrimaryButtonBrush}" />
        </Style>
        <Style Selector="Image.action-icon-image">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Stretch" Value="Uniform" />
        </Style>
        <Style Selector="TextBlock.speaker-menu-icon">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <Grid ColumnDefinitions="16,*"
                              ColumnSpacing="8">
                            <Border x:Name="CheckBoxBorder"
                                    Width="16"
                                    Height="16"
                                    BorderBrush="{DynamicResource TextBrush}"
                                    BorderThickness="1.5"
                                    Background="Transparent"
                                    CornerRadius="3"
                                    VerticalAlignment="Center">
                                <Path x:Name="CheckMark"
                                      Data="M 3 8 L 6.5 11.5 L 13 4.5"
                                      Stroke="{StaticResource EditorButtonTextBrush}"
                                      StrokeThickness="2"
                                      IsVisible="False" />
                            </Border>
                            <ContentPresenter Grid.Column="1"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              VerticalAlignment="Center"
                                              Foreground="{TemplateBinding Foreground}" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="CheckBox:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource OverlayBrush}" />
        </Style>
        <Style Selector="CheckBox:pressed">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource OverlayBrush}" />
        </Style>
        <Style Selector="CheckBox:checked /template/ Border#CheckBoxBorder">
            <Setter Property="Background" Value="{StaticResource EditorPrimaryButtonBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource EditorPrimaryButtonBrush}" />
        </Style>
        <Style Selector="CheckBox:checked /template/ Path#CheckMark">
            <Setter Property="IsVisible" Value="True" />
        </Style>
        <Style Selector="Image.playback-icon-image">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Stretch" Value="Uniform" />
        </Style>
        <Style Selector="Grid.redo-button-host">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>
        <Style Selector="Canvas.redo-square-host">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.redo-spinner-viewport">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Image.redo-icon-host">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Stretch" Value="Uniform" />
        </Style>
    </Window.Styles>

    <Grid>
        <DockPanel x:Name="MainContent">
            <Border DockPanel.Dock="Top"
                    Background="{DynamicResource SurfaceBrush}"
                    Padding="16,10">
                <DockPanel>
                    <TextBlock x:Name="HeaderSubtext"
                               Text="{Binding HeaderSubtext}"
                               DockPanel.Dock="Right"
                               Foreground="{DynamicResource SubtextBrush}"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0" />
                    <TextBlock x:Name="HeaderTitle"
                               Text="{Binding HeaderTitle}"
                               Foreground="{DynamicResource TextBrush}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                </DockPanel>
            </Border>

            <Border x:Name="PlaybackBar"
                    IsEnabled="{Binding CanInteract}"
                    DockPanel.Dock="Bottom"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource OverlayBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="12,8">
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="8">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <Button x:Name="PlayPauseButton"
                                IsEnabled="{Binding CanPlayPause}"
                                Width="36"
                                Height="36"
                                Margin="0,0,4,0"
                                Click="PlayPauseButton_Click">
                            <Grid Width="30" Height="30">
                                <Image Classes="playback-icon-image"
                                       Source="{Binding PlayIconImage}"
                                       Opacity="{Binding IsPlaying, Converter={StaticResource InvBoolToOpacity}}" />
                                <Image Classes="playback-icon-image"
                                       Source="{Binding PauseIconImage}"
                                       Opacity="{Binding IsPlaying, Converter={StaticResource BoolToOpacity}}" />
                            </Grid>
                        </Button>
                        <Button x:Name="PrevButton"
                                IsEnabled="{Binding CanGoPrev}"
                                Width="36"
                                Height="36"
                                Margin="0,0,2,0"
                                Click="PrevButton_Click">
                            <Image Classes="playback-icon-image"
                                   Source="{Binding PrevIconImage}" />
                        </Button>
                        <Button x:Name="NextButton"
                                IsEnabled="{Binding CanGoNext}"
                                Width="36"
                                Height="36"
                                Margin="2,0,8,0"
                                Click="NextButton_Click">
                            <Image Classes="playback-icon-image"
                                   Source="{Binding NextIconImage}" />
                        </Button>
                        <ComboBox x:Name="PlayModeCombo"
                                  ItemsSource="{Binding PlaybackModes}"
                                  SelectedIndex="{Binding SelectedPlaybackModeIndex}"
                                  IsEnabled="{Binding CanChangePlaybackMode}"
                                  MinWidth="100"
                                  Margin="0,0,8,0"
                                  VerticalAlignment="Center"
                                  SelectionChanged="PlayModeCombo_SelectionChanged" />
                    </StackPanel>

                    <Slider Grid.Column="1"
                            x:Name="SeekSlider"
                            Value="{Binding SeekValue}"
                            IsEnabled="{Binding CanSeek}"
                            Minimum="0"
                            Maximum="1"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0" />

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="10"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="SpeedLabel"
                                   Text="{Binding SpeedLabel}"
                                   MinWidth="30"
                                   Margin="0,0,2,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextBrush}" />
                        <Slider x:Name="SpeedSlider"
                                Value="{Binding PlaybackSpeed}"
                                IsEnabled="{Binding CanChangePlaybackSpeed}"
                                Width="80"
                                Margin="4,0,0,0"
                                Minimum="0.2"
                                Maximum="2.0"
                                VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Margin="16,8"
                  ColumnDefinitions="360,*"
                  ColumnSpacing="12"
                  IsEnabled="{Binding CanInteract}">
                <ListBox x:Name="SegmentList"
                         Grid.Column="0"
                         ItemsSource="{Binding Cards}"
                         SelectedItem="{Binding SelectedCard, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectionMode="Single"
                         SelectionChanged="SegmentList_SelectionChanged">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,4,0,4" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Template">
                                <ControlTemplate>
                                    <ContentPresenter Name="PART_ContentPresenter"
                                                      Content="{TemplateBinding Content}"
                                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                                      Padding="{TemplateBinding Padding}" />
                                </ControlTemplate>
                            </Setter>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover">
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                        <Style Selector="ListBoxItem:selected">
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                    </ListBox.Styles>

                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border PointerPressed="SegmentCard_PointerPressed"
                                    Background="{Binding CardBackground}"
                                    BorderBrush="{Binding CardBorderBrush}"
                                    BorderThickness="2"
                                    CornerRadius="8"
                                    Padding="8">
                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="10">
                                        <TextBlock Text="{Binding DraftSpeakerName}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding TimeRangeText}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SubtextBrush}"
                                                   VerticalAlignment="Center" />
                                    </Grid>

                                    <TextBlock Text="{Binding AdjacentPlainText}"
                                               IsVisible="{Binding ShowAdjacentRuns, Converter={StaticResource InvBoolToVis}}"
                                               TextWrapping="Wrap"
                                               MaxHeight="72"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{Binding AdjacentForeground}"
                                               TextDecorations="{Binding AdjacentTextDecorations}" />
                                    <ItemsControl ItemsSource="{Binding AdjacentRuns}"
                                                  IsVisible="{Binding ShowAdjacentRuns, Converter={StaticResource BoolToVis}}"
                                                  MaxHeight="72">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Text}"
                                                           Background="{Binding Background}"
                                                           TextWrapping="NoWrap"
                                                           Foreground="{Binding Foreground}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <ContentControl Grid.Column="1"
                                Content="{Binding SelectedCard}">
                    <ContentControl.ContentTemplate>
                        <DataTemplate>
                            <Border Background="{Binding FocusedBackground}"
                                    BorderBrush="{Binding FocusedBorderBrush}"
                                    BorderThickness="2"
                                    CornerRadius="8"
                                    Padding="12">
                                <StackPanel Spacing="10">
                                    <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto"
                                          ColumnSpacing="8">
                                        <TextBox Text="{Binding DraftSpeakerName, Mode=TwoWay}"
                                                 x:Name="SpeakerNameTextBox"
                                                 MinWidth="130"
                                                 MaxWidth="220"
                                                 HorizontalAlignment="Left"
                                                 KeyDown="SpeakerNameBox_KeyDown"
                                                 PointerWheelChanged="SpeakerNameBox_PointerWheelChanged"
                                                 LostFocus="SpeakerNameBox_LostFocus" />
                                        <Button Grid.Column="1"
                                                Classes="secondary-button action-button"
                                                Click="SpeakerMenu_Click"
                                                ToolTip.Tip="{Binding AddSpeakerTooltip}">
                                            <TextBlock Classes="speaker-menu-icon"
                                                       Text="&#xE77B;" />
                                        </Button>
                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding TimeRangeText}"
                                                   Foreground="{DynamicResource SubtextBrush}"
                                                   VerticalAlignment="Center" />
                                        <CheckBox Grid.Column="4"
                                                  Content="{Binding VerifiedLabel}"
                                                  IsChecked="{Binding IsVerified}"
                                                  VerticalAlignment="Center"
                                                  Click="VerifiedCheckBox_Click" />
                                    </Grid>

                                    <WrapPanel Orientation="Horizontal"
                                               ItemHeight="34">
                                        <Button Classes="secondary-button action-button"
                                                Margin="0,0,8,8"
                                                Click="SuppressButton_Click"
                                                ToolTip.Tip="{Binding SuppressButtonText}">
                                            <Grid Width="28"
                                                  Height="28">
                                                <Image Classes="action-icon-image"
                                                       Source="{Binding SuppressIconImage}"
                                                       Opacity="{Binding IsSuppressed, Converter={StaticResource InvBoolToOpacity}}" />
                                                <Image Classes="action-icon-image"
                                                       Source="{Binding SuppressAlertIconImage}"
                                                       Opacity="{Binding IsSuppressed, Converter={StaticResource BoolToOpacity}}" />
                                            </Grid>
                                        </Button>
                                        <Button Classes="secondary-button action-button"
                                                Margin="0,0,8,8"
                                                Click="AdjustTimes_Click"
                                                IsEnabled="{Binding CanAdjustTimes}"
                                                ToolTip.Tip="{Binding AdjustTimesTooltip}">
                                            <Image Classes="action-icon-image"
                                                   Source="{Binding AdjustTimesIconImage}" />
                                        </Button>
                                        <Button Classes="secondary-button action-button"
                                                Margin="0,0,8,8"
                                                Click="MergePrev_Click"
                                                IsEnabled="{Binding CanMergePrev}"
                                                ToolTip.Tip="{Binding MergePrevTooltip}">
                                            <Image Classes="action-icon-image"
                                                   Source="{Binding MergePrevIconImage}" />
                                        </Button>
                                        <Button Classes="secondary-button action-button"
                                                Margin="0,0,8,8"
                                                Click="MergeNext_Click"
                                                IsEnabled="{Binding CanMergeNext}"
                                                ToolTip.Tip="{Binding MergeNextTooltip}">
                                            <Image Classes="action-icon-image"
                                                   Source="{Binding MergeNextIconImage}" />
                                        </Button>
                                        <Button Classes="secondary-button action-button"
                                                Margin="0,0,8,8"
                                                Click="Split_Click"
                                                IsEnabled="{Binding CanSplit}"
                                                ToolTip.Tip="{Binding SplitTooltip}">
                                            <Image Classes="action-icon-image"
                                                   Source="{Binding SplitIconImage}" />
                                        </Button>
                                        <Button Classes="secondary-button action-button"
                                                Margin="0,0,8,8"
                                                Click="RedoAsr_Click"
                                                IsEnabled="{Binding CanRedoAsr}"
                                                ToolTip.Tip="{Binding RedoAsrTooltip}">
                                            <Grid Classes="redo-button-host">
                                                <Canvas Classes="redo-square-host"
                                                        ClipToBounds="True">
                                                    <Image Classes="redo-icon-host"
                                                           Canvas.Left="2"
                                                           Canvas.Top="2"
                                                           Source="{Binding RedoAsrIconImage}"
                                                           Opacity="{Binding IsRedoAsrSpinning, Converter={StaticResource InvBoolToOpacity}}" />
                                                    <Border Classes="redo-spinner-viewport"
                                                            Canvas.Left="2"
                                                            Canvas.Top="2"
                                                            Opacity="{Binding IsRedoAsrSpinning, Converter={StaticResource BoolToOpacity}}">
                                                        <Image Classes="redo-icon-host"
                                                               Source="{Binding RedoAsrSpinnerImage}"
                                                               Stretch="Fill" />
                                                    </Border>
                                                </Canvas>
                                            </Grid>
                                        </Button>
                                    </WrapPanel>

                                    <Grid ColumnDefinitions="*,*"
                                          ColumnSpacing="10"
                                          MaxHeight="240">
                                        <Border Background="Transparent">
                                            <Grid RowDefinitions="Auto,*"
                                                  RowSpacing="6">
                                                <TextBlock Text="{local:Loc editor_asr_label}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource SubtextBrush}" />
                                                <ScrollViewer Grid.Row="1"
                                                              MaxHeight="214"
                                                              VerticalScrollBarVisibility="Auto"
                                                              HorizontalScrollBarVisibility="Disabled">
                                                    <ItemsControl ItemsSource="{Binding AsrRuns}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Text}"
                                                                           Background="{Binding Background}"
                                                                           TextWrapping="NoWrap"
                                                                           Foreground="{Binding Foreground}" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </Grid>
                                        </Border>

                                        <Border Grid.Column="1"
                                                Background="Transparent">
                                            <Grid RowDefinitions="Auto,*"
                                                  RowSpacing="6">
                                                <TextBlock Text="{local:Loc editor_edit_label}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource SubtextBrush}" />
                                                <TextBox Grid.Row="1"
                                                         x:Name="SegmentContentTextBox"
                                                         Text="{Binding DraftContent, Mode=TwoWay}"
                                                         AcceptsReturn="True"
                                                         TextWrapping="Wrap"
                                                         VerticalContentAlignment="Top"
                                                         MinHeight="84"
                                                         MaxHeight="214"
                                                         FontSize="14"
                                                         Padding="8,6"
                                                         LostFocus="EditTextBox_LostFocus" />
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <TextBlock Text="{Binding StatusMessage}"
                                               Foreground="{DynamicResource SubtextBrush}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ContentControl.ContentTemplate>
                </ContentControl>
            </Grid>
        </DockPanel>

        <Canvas x:Name="SeekBubbleLayer"
                IsHitTestVisible="False">
            <StackPanel x:Name="SeekBubbleHost"
                        IsVisible="False"
                        Spacing="0">
                <Border Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource OverlayBrush}"
                        BorderThickness="1"
                        CornerRadius="4">
                    <TextBlock x:Name="SeekBubbleText"
                               MinWidth="72"
                               Padding="8,3"
                               TextAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource TextBrush}" />
                </Border>
                <TextBlock Text="▼"
                           FontSize="8"
                           HorizontalAlignment="Center"
                           Margin="0,-1,0,0"
                           Foreground="{DynamicResource SubtextBrush}" />
            </StackPanel>
        </Canvas>

        <Border x:Name="LoadingOverlay"
                IsVisible="{Binding IsLoading}"
                Background="#AA000000">
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource OverlayBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="18,14">
                <StackPanel Spacing="8">
                    <ProgressBar IsIndeterminate="True"
                                 Width="240" />
                    <TextBlock Text="Loading transcript editor..."
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextBrush}" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
