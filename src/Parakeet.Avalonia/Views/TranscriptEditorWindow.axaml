<Window x:Class="ParakeetCSharp.Views.TranscriptEditorWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="using:ParakeetCSharp.Converters"
        xmlns:local="using:ParakeetCSharp"
        Title="{local:Loc editor_heading}"
        Width="1040" Height="820"
        MinWidth="820" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:BoolToVisibilityConverter x:Key="InvBoolToVis" Invert="True" />
        <conv:BoolToOpacityConverter x:Key="BoolToOpacity" />
        <conv:BoolToOpacityConverter x:Key="InvBoolToOpacity" Invert="True" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.action-button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>
        <Style Selector="Image.action-icon-image">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Stretch" Value="Uniform" />
        </Style>
        <Style Selector="Image.playback-icon-image">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Stretch" Value="Uniform" />
        </Style>
        <Style Selector="Grid.redo-button-host">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>
        <Style Selector="Canvas.redo-square-host">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.redo-spinner-viewport">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Image.redo-icon-host">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Stretch" Value="Uniform" />
        </Style>
    </Window.Styles>

    <Grid>
        <DockPanel x:Name="MainContent"
                   Margin="18">
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource OverlayBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16,12"
                Margin="0,0,0,14">
            <DockPanel>
                <TextBlock x:Name="HeaderSubtext"
                           Text="{Binding HeaderSubtext}"
                           DockPanel.Dock="Right"
                           Foreground="{DynamicResource SubtextBrush}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0" />
                <TextBlock x:Name="HeaderTitle"
                           Text="{Binding HeaderTitle}"
                           Foreground="{DynamicResource TextBrush}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>

        <Border x:Name="PlaybackBar"
                IsEnabled="{Binding CanInteract}"
                DockPanel.Dock="Bottom"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource OverlayBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="12,10"
                Margin="0,14,0,0">
            <Grid ColumnDefinitions="Auto,* ,Auto"
                  ColumnSpacing="14">
                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                    <Button x:Name="PlayPauseButton"
                            IsEnabled="{Binding CanPlayPause}"
                            Width="38"
                            Height="38"
                            Click="PlayPauseButton_Click">
                        <Grid Width="30" Height="30">
                            <Image Classes="playback-icon-image"
                                   Source="{Binding PlayIconImage}"
                                   Opacity="{Binding IsPlaying, Converter={StaticResource InvBoolToOpacity}}" />
                            <Image Classes="playback-icon-image"
                                   Source="{Binding PauseIconImage}"
                                   Opacity="{Binding IsPlaying, Converter={StaticResource BoolToOpacity}}" />
                        </Grid>
                    </Button>
                    <Button x:Name="PrevButton"
                            IsEnabled="{Binding CanGoPrev}"
                            Width="38"
                            Height="38"
                            Click="PrevButton_Click">
                        <Image Classes="playback-icon-image"
                               Source="{Binding PrevIconImage}" />
                    </Button>
                    <Button x:Name="NextButton"
                            IsEnabled="{Binding CanGoNext}"
                            Width="38"
                            Height="38"
                            Click="NextButton_Click">
                        <Image Classes="playback-icon-image"
                               Source="{Binding NextIconImage}" />
                    </Button>
                    <ComboBox x:Name="PlayModeCombo"
                              ItemsSource="{Binding PlaybackModes}"
                              SelectedIndex="{Binding SelectedPlaybackModeIndex}"
                              IsEnabled="{Binding CanChangePlaybackMode}"
                              MinWidth="140"
                              VerticalAlignment="Center"
                              SelectionChanged="PlayModeCombo_SelectionChanged" />
                </StackPanel>

                <Slider Grid.Column="1"
                        x:Name="SeekSlider"
                        Value="{Binding SeekValue}"
                        IsEnabled="{Binding CanSeek}"
                        Minimum="0"
                        Maximum="1"
                        VerticalAlignment="Center"
                        Margin="0,0,8,0" />

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="10"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="SpeedLabel"
                               Text="{Binding SpeedLabel}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextBrush}" />
                    <Slider x:Name="SpeedSlider"
                            Value="{Binding PlaybackSpeed}"
                            IsEnabled="{Binding CanChangePlaybackSpeed}"
                            Width="110"
                            Minimum="0.2"
                            Maximum="2.0"
                            VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <ListBox x:Name="SegmentList"
                 ItemsSource="{Binding Cards}"
                 SelectedItem="{Binding SelectedCard, Mode=TwoWay}"
                 IsEnabled="{Binding CanInteract}"
                 Background="Transparent"
                 BorderThickness="0"
                 SelectionMode="Single"
                 SelectionChanged="SegmentList_SelectionChanged">
            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,10" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Template">
                        <ControlTemplate>
                            <ContentPresenter Name="PART_ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Padding="{TemplateBinding Padding}" />
                        </ControlTemplate>
                    </Setter>
                </Style>
                <Style Selector="ListBoxItem:pointerover">
                    <Setter Property="Background" Value="Transparent" />
                </Style>
                <Style Selector="ListBoxItem:selected">
                    <Setter Property="Background" Value="Transparent" />
                </Style>
            </ListBox.Styles>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Border IsVisible="{Binding IsFocused, Converter={StaticResource InvBoolToVis}}"
                                Background="{Binding AdjacentBackground}"
                                BorderBrush="{DynamicResource OverlayBrush}"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="14,12">
                            <StackPanel Spacing="8">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="10">
                                    <TextBlock Text="{Binding DraftSpeakerName}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding TimeRangeText}"
                                               FontSize="11"
                                               Foreground="{DynamicResource SubtextBrush}"
                                               VerticalAlignment="Center" />
                                </Grid>

                                <StackPanel Orientation="Horizontal"
                                            Spacing="6">
                                    <Border Background="{DynamicResource GreenBrush}"
                                            CornerRadius="999"
                                            Padding="8,3"
                                            IsVisible="{Binding IsVerified, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{local:Loc editor_verified}"
                                                   FontSize="11"
                                                   Foreground="White" />
                                    </Border>
                                    <Border Background="{DynamicResource RedBrush}"
                                            CornerRadius="999"
                                            Padding="8,3"
                                            IsVisible="{Binding IsSuppressed, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="Suppressed"
                                                   FontSize="11"
                                                   Foreground="White" />
                                    </Border>
                                    <Border Background="{DynamicResource AccentBrush}"
                                            CornerRadius="999"
                                            Padding="8,3"
                                            IsVisible="{Binding HasUserEdits, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="Edited"
                                                   FontSize="11"
                                                   Foreground="White" />
                                    </Border>
                                </StackPanel>

                                <TextBlock Text="{Binding AdjacentPlainText}"
                                           IsVisible="{Binding ShowAdjacentRuns, Converter={StaticResource InvBoolToVis}}"
                                           TextWrapping="Wrap"
                                           MaxHeight="54"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{Binding AdjacentForeground}"
                                           TextDecorations="{Binding AdjacentTextDecorations}" />
                                <ItemsControl ItemsSource="{Binding AdjacentRuns}"
                                              IsVisible="{Binding ShowAdjacentRuns, Converter={StaticResource BoolToVis}}"
                                              MaxHeight="54">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Text}"
                                                       Background="{Binding Background}"
                                                       TextWrapping="NoWrap"
                                                       Foreground="{Binding DataContext.AdjacentForeground, RelativeSource={RelativeSource AncestorType=ContentPresenter}}" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border IsVisible="{Binding IsFocused, Converter={StaticResource BoolToVis}}"
                                Background="{Binding FocusedBackground}"
                                BorderBrush="{Binding FocusedBorderBrush}"
                                BorderThickness="2"
                                CornerRadius="10"
                                Padding="14,12">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto"
                                      ColumnSpacing="8">
                                    <TextBox Text="{Binding DraftSpeakerName, Mode=TwoWay}"
                                             MinWidth="130"
                                             MaxWidth="220"
                                             HorizontalAlignment="Left"
                                             LostFocus="SpeakerNameBox_LostFocus" />
                                    <Button Grid.Column="1"
                                            Content="Rename"
                                            MinWidth="78"
                                            Click="RenameSpeaker_Click" />
                                    <ComboBox Grid.Column="2"
                                              ItemsSource="{Binding SpeakerChoices}"
                                              SelectedItem="{Binding SelectedSpeaker, Mode=TwoWay}"
                                              MinWidth="140" />
                                    <StackPanel Grid.Column="3"
                                                Orientation="Horizontal"
                                                Spacing="8"
                                                HorizontalAlignment="Right">
                                        <Button Classes="secondary-button action-button"
                                                Click="ReassignSpeaker_Click"
                                                ToolTip.Tip="Reassign">
                                            <Image Classes="action-icon-image"
                                                   Source="{Binding ReassignSpeakerIconImage}" />
                                        </Button>
                                        <Button Classes="secondary-button action-button"
                                                Click="AddSpeaker_Click"
                                                ToolTip.Tip="{local:Loc editor_add_speaker}">
                                            <Image Classes="action-icon-image"
                                                   Source="{Binding AddSpeakerIconImage}" />
                                        </Button>
                                    </StackPanel>
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding TimeRangeText}"
                                               Foreground="{DynamicResource SubtextBrush}"
                                               VerticalAlignment="Center" />
                                    <CheckBox Grid.Column="5"
                                              Content="{local:Loc editor_verified}"
                                              IsChecked="{Binding IsVerified}"
                                              VerticalAlignment="Center"
                                              Click="VerifiedCheckBox_Click" />
                                </Grid>

                                <WrapPanel Orientation="Horizontal"
                                           ItemHeight="34">
                                    <Button Classes="secondary-button action-button"
                                            Margin="0,0,8,8"
                                            Click="SuppressButton_Click"
                                            ToolTip.Tip="{Binding SuppressButtonText}">
                                        <Grid Width="28"
                                              Height="28">
                                            <Image Classes="action-icon-image"
                                                   Source="{Binding SuppressIconImage}"
                                                   Opacity="{Binding IsSuppressed, Converter={StaticResource InvBoolToOpacity}}" />
                                            <Image Classes="action-icon-image"
                                                   Source="{Binding SuppressAlertIconImage}"
                                                   Opacity="{Binding IsSuppressed, Converter={StaticResource BoolToOpacity}}" />
                                        </Grid>
                                    </Button>
                                    <Button Classes="secondary-button action-button"
                                            Margin="0,0,8,8"
                                            Click="AdjustTimes_Click"
                                            IsEnabled="{Binding CanAdjustTimes}"
                                            ToolTip.Tip="{local:Loc editor_adjust_times}">
                                        <Image Classes="action-icon-image"
                                               Source="{Binding AdjustTimesIconImage}" />
                                    </Button>
                                    <Button Classes="secondary-button action-button"
                                            Margin="0,0,8,8"
                                            Click="MergePrev_Click"
                                            IsEnabled="{Binding CanMergePrev}"
                                            ToolTip.Tip="{local:Loc editor_merge_prev}">
                                        <Image Classes="action-icon-image"
                                               Source="{Binding MergePrevIconImage}" />
                                    </Button>
                                    <Button Classes="secondary-button action-button"
                                            Margin="0,0,8,8"
                                            Click="MergeNext_Click"
                                            IsEnabled="{Binding CanMergeNext}"
                                            ToolTip.Tip="{local:Loc editor_merge_next}">
                                        <Image Classes="action-icon-image"
                                               Source="{Binding MergeNextIconImage}" />
                                    </Button>
                                    <Button Classes="secondary-button action-button"
                                            Margin="0,0,8,8"
                                            Click="Split_Click"
                                            IsEnabled="{Binding CanSplit}"
                                            ToolTip.Tip="{local:Loc editor_split}">
                                        <Image Classes="action-icon-image"
                                               Source="{Binding SplitIconImage}" />
                                    </Button>
                                    <Button Classes="secondary-button action-button"
                                            Margin="0,0,8,8"
                                            Click="RedoAsr_Click"
                                            IsEnabled="{Binding CanRedoAsr}"
                                            ToolTip.Tip="{local:Loc editor_redo_asr}">
                                        <Grid Classes="redo-button-host">
                                            <Canvas Classes="redo-square-host"
                                                    ClipToBounds="True">
                                                <Image Classes="redo-icon-host"
                                                       Canvas.Left="2"
                                                       Canvas.Top="2"
                                                       Source="{Binding RedoAsrIconImage}"
                                                       Opacity="{Binding IsRedoAsrSpinning, Converter={StaticResource InvBoolToOpacity}}" />
                                                <Border Classes="redo-spinner-viewport"
                                                        Canvas.Left="2"
                                                        Canvas.Top="2"
                                                        Opacity="{Binding IsRedoAsrSpinning, Converter={StaticResource BoolToOpacity}}">
                                                    <Image Classes="redo-icon-host"
                                                           Source="{Binding RedoAsrSpinnerImage}"
                                                           Stretch="Fill" />
                                                </Border>
                                            </Canvas>
                                        </Grid>
                                    </Button>
                                </WrapPanel>

                                <Grid ColumnDefinitions="*,*"
                                      ColumnSpacing="10"
                                      Height="240">
                                    <Border Background="Transparent">
                                        <Grid RowDefinitions="Auto,*"
                                              RowSpacing="6">
                                            <TextBlock Text="{local:Loc editor_asr_label}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SubtextBrush}" />
                                            <ScrollViewer Grid.Row="1"
                                                          VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled">
                                                <ItemsControl ItemsSource="{Binding AsrRuns}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Text}"
                                                                       Background="{Binding Background}"
                                                                       TextWrapping="NoWrap"
                                                                       Foreground="{DynamicResource TextBrush}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="1"
                                            Background="Transparent">
                                        <Grid RowDefinitions="Auto,*"
                                              RowSpacing="6">
                                            <TextBlock Text="{local:Loc editor_edit_label}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SubtextBrush}" />
                                            <TextBox Grid.Row="1"
                                                     Text="{Binding DraftContent, Mode=TwoWay}"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"
                                                     VerticalContentAlignment="Top"
                                                     MinHeight="180"
                                                     FontSize="14"
                                                     Padding="8,6"
                                                     LostFocus="EditTextBox_LostFocus" />
                                        </Grid>
                                    </Border>
                                </Grid>

                                <TextBlock Text="{Binding StatusMessage}"
                                           Foreground="{DynamicResource SubtextBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        </DockPanel>

        <Border x:Name="LoadingOverlay"
                IsVisible="{Binding IsLoading}"
                Background="#AA000000">
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource OverlayBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="18,14">
                <StackPanel Spacing="8">
                    <ProgressBar IsIndeterminate="True"
                                 Width="240" />
                    <TextBlock Text="Loading transcript editor..."
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextBrush}" />
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
