<Window x:Class="ParakeetCSharp.Views.Dialogs.AdjustTimesDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adjust Segment Times"
        Width="320" Height="200"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}">

    <StackPanel Margin="20">

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="Start time (seconds)"
                       Foreground="{DynamicResource TextBrush}"
                       VerticalAlignment="Center"/>
            <TextBox   Grid.Row="0" Grid.Column="1"
                       x:Name="StartBox"
                       Foreground="{DynamicResource TextBrush}"
                       Background="{DynamicResource SurfaceBrush}"
                       BorderBrush="{DynamicResource OverlayBrush}"
                       Padding="4,2"/>

            <TextBlock Grid.Row="2" Grid.Column="0"
                       Text="End time (seconds)"
                       Foreground="{DynamicResource TextBrush}"
                       VerticalAlignment="Center"/>
            <TextBox   Grid.Row="2" Grid.Column="1"
                       x:Name="EndBox"
                       Foreground="{DynamicResource TextBrush}"
                       Background="{DynamicResource SurfaceBrush}"
                       BorderBrush="{DynamicResource OverlayBrush}"
                       Padding="4,2"/>
        </Grid>

        <TextBlock x:Name="ErrorLabel"
                   Foreground="{DynamicResource RedBrush}"
                   FontSize="11"
                   IsVisible="Collapsed"
                   Margin="0,0,0,8"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="OkBtn"     Content="OK"     Width="72" Margin="0,0,8,0" Click="OkBtn_Click"/>
            <Button x:Name="CancelBtn" Content="Cancel" Width="72"                   Click="CancelBtn_Click"/>
        </StackPanel>

    </StackPanel>
</Window>
