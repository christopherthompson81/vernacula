<Window x:Class="ParakeetCSharp.Views.Dialogs.NewTranscriptionWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:ParakeetCSharp"
        xmlns:v="using:ParakeetCSharp.Views"
        Title="{local:Loc menu_new_transcription}"
        Width="540"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Icon="avares://Parakeet.Avalonia/Assets/icon.ico"
        Background="{DynamicResource BgBrush}">

    <v:ConfigView />

</Window>
