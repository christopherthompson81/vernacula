<Window x:Class="ParakeetCSharp.Views.Dialogs.SplitSegmentDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Split Segment"
        Width="560" Height="420"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}">

    <DockPanel Margin="16">

        <TextBlock DockPanel.Dock="Top"
                   Text="Click the token where the second segment should begin."
                   Foreground="{DynamicResource SubtextBrush}"
                   FontSize="12"
                   Margin="0,0,0,10"/>

        <!-- Preview pane -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource OverlayBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8"
                Margin="0,10,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="First:"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               MinWidth="48"/>
                    <TextBlock x:Name="FirstPreview"
                               Foreground="{DynamicResource SubtextBrush}"
                               TextWrapping="Wrap"
                               Text="(select a split point above)"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Second:"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               MinWidth="48"/>
                    <TextBlock x:Name="SecondPreview"
                               Foreground="{DynamicResource SubtextBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="OkBtn"     Content="Split"  Width="72" Margin="0,0,8,0"
                            IsEnabled="False"   Click="OkBtn_Click"/>
                    <Button x:Name="CancelBtn" Content="Cancel" Width="72"
                            Click="CancelBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Token scroll area -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <WrapPanel x:Name="TokenPanel" Margin="0,0,0,4"/>
        </ScrollViewer>

    </DockPanel>
</Window>
