<UserControl x:Class="ParakeetCSharp.Views.ResultsView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:ParakeetCSharp"
             xmlns:conv="using:ParakeetCSharp.Converters"
             xmlns:vm="using:ParakeetCSharp.ViewModels"
             x:DataType="vm:ResultsViewModel">

    <UserControl.Resources>
        <conv:SecondsToTimeConverter x:Key="SecondsToTime" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Audio file name -->
            <RowDefinition Height="Auto" />   <!-- Segment count -->
            <RowDefinition Height="*"    />   <!-- Segments table -->
            <RowDefinition Height="Auto" />   <!-- Action buttons -->
        </Grid.RowDefinitions>

        <!-- Header: audio file name -->
        <TextBlock Grid.Row="0"
                   Foreground="{DynamicResource TextBrush}"
                   Text="{Binding AudioBaseName}"
                   FontSize="20" FontWeight="SemiBold"
                   Margin="0,0,0,4" />

        <!-- Segment count subtitle -->
        <TextBlock Grid.Row="1"
                   Foreground="{DynamicResource SubtextBrush}"
                   Margin="0,0,0,16">
            <Run Text="{Binding Segments.Count, Mode=OneWay}" />
            <Run Text="{local:Loc results_segments_label}" />
        </TextBlock>

        <!-- Segments table -->
        <DataGrid x:Name="SegmentsGrid"
                  Grid.Row="2"
                  Margin="0,0,0,12"
                  ItemsSource="{Binding Segments}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserReorderColumns="False"
                  
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding SpeakerDisplayName}" Width="110">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{Binding Source={x:Static local:Loc.Instance}, Path=[segments_col_speaker]}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding StartTime, Converter={StaticResource SecondsToTime}}" Width="70">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{Binding Source={x:Static local:Loc.Instance}, Path=[segments_col_start]}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding EndTime, Converter={StaticResource SecondsToTime}}" Width="70">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{Binding Source={x:Static local:Loc.Instance}, Path=[segments_col_end]}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding Text}" Width="*">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{Binding Source={x:Static local:Loc.Instance}, Path=[segments_col_content]}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Action buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <!-- TODO: Enable when TranscriptEditorWindow is ported -->
            <Button Content="{local:Loc btn_edit_transcript}"
                    Classes="secondary-button"
                    Command="{Binding EditTranscriptCommand}"
                    IsEnabled="False"
                    Margin="0,0,8,0" />
            <Button Content="{local:Loc btn_edit_speakers}"
                    Classes="secondary-button"
                    Command="{Binding EditSpeakerNamesCommand}"
                    Margin="0,0,8,0" />
            <Button Content="{local:Loc btn_export}"
                    Command="{Binding ExportCommand}"
                    Margin="0,0,8,0" />
            <Button Content="{local:Loc btn_back_history}"
                    Classes="secondary-button"
                    Command="{Binding BackCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
