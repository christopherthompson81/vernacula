<UserControl x:Class="ParakeetCSharp.Views.ConfigView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:ParakeetCSharp"
             xmlns:vm="using:ParakeetCSharp.ViewModels"
             x:DataType="vm:ConfigViewModel">

    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="480">

        <Border Background="{DynamicResource SurfaceBrush}"
                CornerRadius="8"
                Padding="24"
                Margin="0,0,0,12">
            <StackPanel>
                <TextBlock x:Name="ConfigHeadingText"
                           Text="{local:Loc config_heading}"
                           Foreground="{DynamicResource TextBrush}"
                           FontSize="20" FontWeight="SemiBold"
                           Margin="0,0,0,20" />

                <!-- Audio file -->
                <TextBlock x:Name="AudioFileLabelText"
                           Text="{local:Loc label_audio_file}"
                           Foreground="{DynamicResource TextBrush}"
                           Margin="0,0,0,4" />
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding AudioFilePath}"
                             Foreground="{DynamicResource TextBrush}"
                             Background="{DynamicResource SurfaceBrush}"
                             BorderBrush="{DynamicResource OverlayBrush}"
                             IsReadOnly="True"
                             Margin="0,0,8,0" />
                    <Button x:Name="BrowseButton"
                            Grid.Column="1"
                            Content="{local:Loc btn_browse}"
                            Classes="secondary-button"
                            Command="{Binding SelectAudioFileCommand}" />
                </Grid>

                <!-- Job name -->
                <TextBlock x:Name="JobNameLabelText"
                           Text="{local:Loc label_job_name}"
                           Foreground="{DynamicResource TextBrush}"
                           Margin="0,0,0,4" />
                <TextBox Text="{Binding JobName, UpdateSourceTrigger=PropertyChanged}"
                         Foreground="{DynamicResource TextBrush}"
                         Background="{DynamicResource SurfaceBrush}"
                         BorderBrush="{DynamicResource OverlayBrush}" />
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,0,0,12">
            <Button x:Name="BackButton"
                    Content="{local:Loc btn_back}"
                    Classes="secondary-button"
                    Command="{Binding BackCommand}"
                    Margin="0,0,8,0" />
            <Button x:Name="StartButton"
                    Content="{local:Loc btn_start}"
                    Command="{Binding StartCommand}" />
        </StackPanel>

    </StackPanel>
</UserControl>
