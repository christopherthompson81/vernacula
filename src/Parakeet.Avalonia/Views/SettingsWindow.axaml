<Window x:Class="ParakeetCSharp.Views.SettingsWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:ParakeetCSharp"
        xmlns:conv="using:ParakeetCSharp.Converters"
        xmlns:vm="using:ParakeetCSharp.ViewModels"
        x:DataType="vm:SettingsViewModel"
        Title="{local:Loc settings_window_title}"
        Icon="avares://Parakeet.Avalonia/Assets/icon.ico"
        Width="580" Height="720"
        MinWidth="480" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}"
        Loaded="Window_Loaded">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:BoolToVisibilityConverter x:Key="InvBoolToVis" Invert="True" />
        <conv:BoolToStatusIconConverter x:Key="BoolToStatusIcon" />
        <conv:BoolToStatusBrushConverter x:Key="BoolToStatusBrush" />
        <conv:BoolToStatusBrushConverter x:Key="BoolToStatusBrushYellow" FalseBrushKey="YellowBrush" />
        <conv:BoolToStatusBrushConverter x:Key="BoolToStatusBrushSubtext" FalseBrushKey="SubtextBrush" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TextBlock.section-heading">
            <Setter Property="FontSize"   Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}" />
            <Setter Property="Margin"     Value="0,20,0,6" />
        </Style>

        <Style Selector="TextBlock.check-label">
            <Setter Property="Foreground"        Value="{DynamicResource TextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="Button.link-button">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="Foreground"      Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="4,2" />
        </Style>
    </Window.Styles>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="20,4,20,4">
            <StackPanel MaxWidth="540">

                <!-- ─── Hardware & Performance ──────────────────────────────── -->
                <TextBlock Text="{local:Loc settings_section_hardware}"
                           Classes="section-heading" />

                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel>

                        <!-- Checking spinner (visible while running) -->
                        <TextBlock Text="{local:Loc settings_hw_checking}"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   Margin="0,0,0,8"
                                   IsVisible="{Binding IsCheckingHardware,
                                                        Converter={StaticResource BoolToVis}}" />

                        <!-- Hardware rows (hidden while checking) -->
                        <StackPanel IsVisible="{Binding IsCheckingHardware,
                                                         Converter={StaticResource InvBoolToVis}}">

                            <!-- NVIDIA GPU -->
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22" />
                                    <ColumnDefinition Width="*"  />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           Text="{Binding GpuDetected, Converter={StaticResource BoolToStatusIcon}}"
                                           Foreground="{Binding GpuDetected, Converter={StaticResource BoolToStatusBrushSubtext}}" />
                                <TextBlock Grid.Column="1" Text="NVIDIA GPU"
                                           Classes="check-label" />
                                <TextBlock Grid.Column="2" Text="{Binding GpuVramText}"
                                           Foreground="{DynamicResource SubtextBrush}"
                                           VerticalAlignment="Center" FontSize="12" />
                            </Grid>

                            <!-- CUDA checks — only shown when an NVIDIA GPU is present -->
                            <StackPanel IsVisible="{Binding GpuDetected,
                                                             Converter={StaticResource BoolToVis}}">

                                <!-- CUDA Toolkit -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22" />
                                        <ColumnDefinition Width="*"  />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               Text="{Binding CudaToolkitInstalled, Converter={StaticResource BoolToStatusIcon}}"
                                               Foreground="{Binding CudaToolkitInstalled, Converter={StaticResource BoolToStatusBrushYellow}}" />
                                    <TextBlock Grid.Column="1" Text="{local:Loc settings_hw_cuda_toolkit}"
                                               Classes="check-label" />
                                    <Button Grid.Column="2"
                                            Content="{local:Loc settings_hw_download_cuda}"
                                            Classes="link-button"
                                            Command="{Binding OpenCudaDownloadPageCommand}"
                                            IsVisible="{Binding CudaToolkitInstalled,
                                                                 Converter={StaticResource InvBoolToVis}}" />
                                </Grid>

                                <!-- cuDNN -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22" />
                                        <ColumnDefinition Width="*"  />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               Text="{Binding CudnnInstalled, Converter={StaticResource BoolToStatusIcon}}"
                                               Foreground="{Binding CudnnInstalled, Converter={StaticResource BoolToStatusBrushYellow}}" />
                                    <TextBlock Grid.Column="1" Text="{local:Loc settings_hw_cudnn}"
                                               Classes="check-label" />
                                    <Button Grid.Column="2"
                                            Content="{local:Loc settings_hw_download_cudnn}"
                                            Classes="link-button"
                                            Command="{Binding OpenCudnnDownloadPageCommand}"
                                            IsVisible="{Binding CudnnInstalled,
                                                                 Converter={StaticResource InvBoolToVis}}" />
                                </Grid>

                                <!-- CUDA EP active -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22" />
                                        <ColumnDefinition Width="*"  />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               Text="{Binding CudaEpWorking, Converter={StaticResource BoolToStatusIcon}}"
                                               Foreground="{Binding CudaEpWorking, Converter={StaticResource BoolToStatusBrushSubtext}}" />
                                    <TextBlock Grid.Column="1" Text="{local:Loc settings_hw_cuda_ep}"
                                               Classes="check-label" />
                                </Grid>

                            </StackPanel>

                            <!-- No GPU message — shown when no acceleratable GPU is present -->
                            <TextBlock Text="{local:Loc settings_hw_no_gpu}"
                                       Foreground="{DynamicResource SubtextBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"
                                       IsVisible="{Binding GpuDetected,
                                                            Converter={StaticResource InvBoolToVis}}" />

                            <!-- Batch ceiling -->
                            <TextBlock Text="{Binding BatchCeilingText}"
                                       Foreground="{DynamicResource SubtextBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12" />

                        </StackPanel>

                        <!-- Re-check button (always shown) -->
                        <Button Content="{local:Loc settings_hw_recheck}"
                                Classes="secondary-button"
                                Command="{Binding RecheckHardwareCommand}"
                                HorizontalAlignment="Left"
                                IsEnabled="{Binding IsCheckingHardware,
                                                    Converter={StaticResource InvBoolToVis}}" />
                    </StackPanel>
                </Border>

                <!-- ─── Models ───────────────────────────────────────────────── -->
                <TextBlock Text="{local:Loc settings_section_models}"
                           Classes="section-heading" />

                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel>

                        <!-- Model status -->
                        <TextBlock Text="{Binding ModelStatusText}"
                                   Foreground="{Binding ModelStatusBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10" />

                        <!-- Update / hash-check banner -->
                        <Border IsVisible="{Binding UpdateBannerVisible,
                                                     Converter={StaticResource BoolToVis}}"
                                Background="{DynamicResource OverlayBrush}"
                                CornerRadius="4"
                                Padding="10,8"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"    />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding UpdateBannerText}"
                                           Foreground="{DynamicResource TextBrush}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        Content="{local:Loc btn_update_models}"
                                        Command="{Binding UpdateModelsCommand}"
                                        Margin="8,0,4,0"
                                        IsVisible="{Binding HasOutdatedFiles,
                                                             Converter={StaticResource BoolToVis}}" />
                                <Button Grid.Column="2"
                                        Content="{local:Loc btn_dismiss}"
                                        Classes="secondary-button"
                                        Command="{Binding DismissUpdateBannerCommand}" />
                            </Grid>
                        </Border>

                        <!-- Download progress bar + status text -->
                        <StackPanel IsVisible="{Binding IsDownloading,
                                                         Converter={StaticResource BoolToVis}}"
                                    Margin="0,0,0,10">
                            <ProgressBar Value="{Binding DownloadPercent}"
                                         Minimum="0" Maximum="100"
                                         Margin="0,0,0,4" />
                            <TextBlock Text="{Binding DownloadStatusText}"
                                       Foreground="{DynamicResource SubtextBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <!-- Action buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Button Content="{local:Loc btn_download_models}"
                                    Command="{Binding DownloadModelsCommand}"
                                    Margin="0,0,8,0"
                                    IsVisible="{Binding DownloadVisible,
                                                         Converter={StaticResource BoolToVis}}"
                                    IsEnabled="{Binding IsDownloading,
                                                        Converter={StaticResource InvBoolToVis}}" />
                            <Button Content="{local:Loc btn_cancel}"
                                    Classes="secondary-button"
                                    Command="{Binding CancelDownloadCommand}"
                                    Margin="0,0,8,0"
                                    IsVisible="{Binding IsDownloading,
                                                         Converter={StaticResource BoolToVis}}" />
                            <Button Content="{local:Loc btn_check_updates}"
                                    Classes="secondary-button"
                                    Command="{Binding CheckForUpdatesCommand}"
                                    IsEnabled="{Binding IsCheckingUpdates,
                                                        Converter={StaticResource InvBoolToVis}}"
                                    IsVisible="{Binding ModelsReady,
                                                         Converter={StaticResource BoolToVis}}" />
                        </StackPanel>

                        <!-- Precision -->
                        <Separator Background="{DynamicResource OverlayBrush}" Margin="0,0,0,12" />
                        <TextBlock Text="{local:Loc menu_model_precision}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="{local:Loc menu_precision_fp16}"
                                         Foreground="{DynamicResource TextBrush}"
                                         GroupName="Precision"
                                         IsChecked="{Binding IsFp32, Mode=OneWay}"
                                         Command="{Binding SetPrecisionCommand}"
                                         CommandParameter="Fp32"
                                         Margin="0,0,20,0" />
                            <RadioButton Content="{local:Loc menu_precision_int8}"
                                         Foreground="{DynamicResource TextBrush}"
                                         GroupName="Precision"
                                         IsChecked="{Binding IsInt8, Mode=OneWay}"
                                         Command="{Binding SetPrecisionCommand}"
                                         CommandParameter="Int8" />
                        </StackPanel>

                    </StackPanel>
                </Border>

                <!-- ─── Segmentation ────────────────────────────────────────── -->
                <TextBlock Text="{local:Loc settings_section_segmentation}"
                           Classes="section-heading" />

                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel>

                        <!-- VAD option -->
                        <RadioButton GroupName="Segmentation"
                                     IsChecked="{Binding IsVoiceActivity, Mode=OneWay}"
                                     Command="{Binding SetSegmentationCommand}"
                                     CommandParameter="VoiceActivity"
                                     Foreground="{DynamicResource TextBrush}"
                                     Margin="0,0,0,4">
                            <StackPanel>
                                <TextBlock Text="{local:Loc settings_segmentation_vad}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock Text="{local:Loc settings_segmentation_vad_desc}"
                                           Foreground="{DynamicResource SubtextBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </RadioButton>

                        <Separator Background="{DynamicResource OverlayBrush}" Margin="0,8,0,8" />

                        <!-- Diarization option -->
                        <RadioButton GroupName="Segmentation"
                                     IsChecked="{Binding IsDiarization, Mode=OneWay}"
                                     Command="{Binding SetSegmentationCommand}"
                                     CommandParameter="Diarization"
                                     Foreground="{DynamicResource TextBrush}">
                            <StackPanel>
                                <TextBlock Text="{local:Loc settings_segmentation_diarization}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock Text="{local:Loc settings_segmentation_diarization_desc}"
                                           Foreground="{DynamicResource SubtextBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </RadioButton>

                    </StackPanel>
                </Border>

                <!-- ─── Transcript Editor ───────────────────────────────────── -->
                <TextBlock Text="{local:Loc settings_section_editor}"
                           Classes="section-heading" />

                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="{local:Loc settings_editor_playback_mode}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="{local:Loc editor_mode_continuous}"
                                         Foreground="{DynamicResource TextBrush}"
                                         GroupName="EditorPlayback"
                                         IsChecked="{Binding IsEditorContinuous, Mode=OneWay}"
                                         Command="{Binding SetEditorPlaybackModeCommand}"
                                         CommandParameter="Continuous"
                                         Margin="0,0,20,0" />
                            <RadioButton Content="{local:Loc editor_mode_single}"
                                         Foreground="{DynamicResource TextBrush}"
                                         GroupName="EditorPlayback"
                                         IsChecked="{Binding IsEditorSingle, Mode=OneWay}"
                                         Command="{Binding SetEditorPlaybackModeCommand}"
                                         CommandParameter="Single"
                                         Margin="0,0,20,0" />
                            <RadioButton Content="{local:Loc editor_auto_advance}"
                                         Foreground="{DynamicResource TextBrush}"
                                         GroupName="EditorPlayback"
                                         IsChecked="{Binding IsEditorAutoAdvance, Mode=OneWay}"
                                         Command="{Binding SetEditorPlaybackModeCommand}"
                                         CommandParameter="AutoAdvance" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ─── Appearance ───────────────────────────────────────────── -->
                <TextBlock Text="{local:Loc settings_section_appearance}"
                           Classes="section-heading" />

                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="{local:Loc menu_theme}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal">
                            <RadioButton Content="{local:Loc menu_theme_dark}"
                                         Foreground="{DynamicResource TextBrush}"
                                         GroupName="Theme"
                                         IsChecked="{Binding IsDark, Mode=OneWay}"
                                         Command="{Binding SetThemeCommand}"
                                         CommandParameter="Dark"
                                         Margin="0,0,20,0" />
                            <RadioButton Content="{local:Loc menu_theme_light}"
                                         Foreground="{DynamicResource TextBrush}"
                                         GroupName="Theme"
                                         IsChecked="{Binding IsLight, Mode=OneWay}"
                                         Command="{Binding SetThemeCommand}"
                                         CommandParameter="Light" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ─── Language ─────────────────────────────────────────────── -->
                <TextBlock Text="{local:Loc settings_section_language}"
                           Classes="section-heading" />

                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="8" Padding="16"
                        Margin="0,0,0,16">
                    <ComboBox ItemsSource="{x:Static local:Loc.Languages}"
                              SelectedItem="{Binding SelectedLanguage}"
                              Background="{DynamicResource OverlayBrush}"
                              Foreground="{DynamicResource TextBrush}"
                              BorderBrush="{DynamicResource OverlayBrush}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ─── Footer ───────────────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource OverlayBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Button Content="{local:Loc btn_ok}"
                    Classes="secondary-button"
                    HorizontalAlignment="Right"
                    Click="Close_Click" />
        </Border>
    </Grid>
</Window>
