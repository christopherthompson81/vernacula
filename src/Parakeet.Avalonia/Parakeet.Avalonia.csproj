<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <BuiltInComInteropSupport>true</BuiltInComInteropSupport>
    <ApplicationIcon>Assets/icon.ico</ApplicationIcon>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <PropertyGroup>
    <AvaloniaUseCompiledBindingsByDefault>false</AvaloniaUseCompiledBindingsByDefault>
  </PropertyGroup>

  <ItemGroup>
    <!-- Exclude TranscriptEditorWindow - TODO: Port rich text editing -->
    <Compile Remove="Views\TranscriptEditorWindow.axaml.cs" />
    <AvaloniaXaml Remove="Views\TranscriptEditorWindow.axaml" />
    <Compile Remove="ViewModels\TranscriptEditorViewModel.cs" />
  </ItemGroup>

  <ItemGroup>
    <AvaloniaResource Include="Assets\**" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Locales\*.json" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Help\en\**\*.md" />
    <EmbeddedResource Include="Help\de\**\*.md" />
    <EmbeddedResource Include="Help\es\**\*.md" />
    <EmbeddedResource Include="Help\fr\**\*.md" />
    <EmbeddedResource Include="Help\it\**\*.md" />
    <EmbeddedResource Include="Help\pl\**\*.md" />
    <EmbeddedResource Include="Help\pt\**\*.md" />
    <EmbeddedResource Include="Help\ru\**\*.md" />
    <EmbeddedResource Include="Help\sv\**\*.md" />
    <EmbeddedResource Include="Help\bg\**\*.md" />
    <EmbeddedResource Include="Help\cs\**\*.md" />
    <EmbeddedResource Include="Help\da\**\*.md" />
    <EmbeddedResource Include="Help\el\**\*.md" />
    <EmbeddedResource Include="Help\et\**\*.md" />
    <EmbeddedResource Include="Help\fi\**\*.md" />
    <EmbeddedResource Include="Help\hr\**\*.md" />
    <EmbeddedResource Include="Help\hu\**\*.md" />
    <EmbeddedResource Include="Help\lt\**\*.md" />
    <EmbeddedResource Include="Help\lv\**\*.md" />
    <EmbeddedResource Include="Help\mt\**\*.md" />
    <EmbeddedResource Include="Help\nl\**\*.md" />
    <EmbeddedResource Include="Help\ro\**\*.md" />
    <EmbeddedResource Include="Help\sk\**\*.md" />
    <EmbeddedResource Include="Help\sl\**\*.md" />
    <EmbeddedResource Include="Help\uk\**\*.md" />
    <EmbeddedResource Include="Help\ja\**\*.md" />
    <EmbeddedResource Include="Help\ko\**\*.md" />
    <EmbeddedResource Include="Help\tr\**\*.md" />
    <EmbeddedResource Include="Help\zh\**\*.md" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="11.3.9" />
    <PackageReference Include="Markdown.Avalonia" Version="11.0.3-a1" />
    <PackageReference Include="Markdig" Version="0.34.0" />
    <PackageReference Include="Avalonia.Desktop" Version="11.3.9" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="11.3.9" />
    <PackageReference Include="Avalonia.Fonts.Inter" Version="11.3.9" />
    <PackageReference Include="Avalonia.Controls.DataGrid" Version="11.3.9" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
    <PackageReference Include="FFmpeg.AutoGen" Version="7.1.1" />

    <PackageReference Include="MathNet.Numerics" Version="5.0.0" />
    <PackageReference Include="Microsoft.Data.Sqlite" Version="9.0.4" />
    <PackageReference Include="NAudio" Version="2.2.1" />
    <PackageReference Include="SoundTouch.Net" Version="2.1.2" />
    <PackageReference Include="ClosedXML" Version="0.104.1" />
    <PackageReference Include="DocumentFormat.OpenXml" Version="3.3.0" />
  </ItemGroup>

  <ItemGroup>
    <!-- Platform-specific ONNX Runtime -->
    <PackageReference Include="Microsoft.ML.OnnxRuntime.Gpu" Version="1.24.2" Condition="'$(UseDirectML)' != 'true' AND $([MSBuild]::IsOSPlatform('Windows'))" />
    <PackageReference Include="Microsoft.ML.OnnxRuntime.DirectML" Version="1.21.1" Condition="'$(UseDirectML)' == 'true' AND $([MSBuild]::IsOSPlatform('Windows'))" />
    <PackageReference Include="Microsoft.ML.OnnxRuntime" Version="1.24.2" Condition="'$(UseDirectML)' != 'true' AND !$([MSBuild]::IsOSPlatform('Windows'))" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Parakeet.Base\Parakeet.Base.csproj" />
  </ItemGroup>

</Project>
