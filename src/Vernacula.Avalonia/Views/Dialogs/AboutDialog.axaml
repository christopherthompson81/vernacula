<Window x:Class="Vernacula.App.Views.Dialogs.AboutDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Vernacula.App"
        Title="{local:Loc about_title}"
        Icon="avares://Vernacula.Avalonia/Assets/icon.ico"
        MinWidth="480" MinHeight="220" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource BgBrush}">

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Parakeet image, left-aligned -->
        <Image Grid.Column="0"
               Source="avares://Vernacula.Avalonia/Assets/parakeet.png"
               Height="140"
               VerticalAlignment="Center"
               Margin="0,0,20,0"
               Stretch="Uniform" />

        <!-- Text + OK button -->
        <Grid Grid.Column="1" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock x:Name="AboutHeadingText" Text="{local:Loc about_heading}"
                           Foreground="{DynamicResource TextBrush}"
                           FontSize="18" FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <TextBlock x:Name="AboutDescriptionText" Text="{local:Loc about_description}"
                           Foreground="{DynamicResource SubtextBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,4" />
                <TextBlock x:Name="AboutTechText" Text="{local:Loc about_tech}"
                           Foreground="{DynamicResource SubtextBrush}"
                           Margin="0,0,0,4" />
                <TextBlock x:Name="AboutCreditText" Text="{local:Loc about_credit}"
                           Foreground="{DynamicResource SubtextBrush}" />
            </StackPanel>

            <Button x:Name="AboutOkButton" Grid.Row="1"
                    Content="{local:Loc btn_ok}"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0"
                    Click="OK_Click" />
        </Grid>
    </Grid>
</Window>
