<Window x:Class="Vernacula.Avalonia.Views.Dialogs.NewTranscriptionWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Vernacula.Avalonia"
        xmlns:v="using:Vernacula.Avalonia.Views"
        Title="{local:Loc menu_new_transcription}"
        Width="540"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        Icon="avares://Vernacula.Avalonia/Assets/icon.ico"
        Background="{DynamicResource BgBrush}">

    <v:ConfigView />

</Window>
