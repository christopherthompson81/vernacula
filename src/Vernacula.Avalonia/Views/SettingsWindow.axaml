<Window x:Class="Vernacula.App.Views.SettingsWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:Vernacula.App"
        xmlns:conv="using:Vernacula.App.Converters"
        xmlns:vm="using:Vernacula.App.ViewModels"
        x:DataType="vm:SettingsViewModel"
        Title="{Binding Source={x:Static local:Loc.Instance}, Path=[settings_window_title]}"
        Icon="avares://Vernacula.Avalonia/Assets/icon.ico"
        Width="580" Height="720"
        MinWidth="480" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgBrush}"
        Loaded="Window_Loaded">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:BoolToVisibilityConverter x:Key="InvBoolToVis" Invert="True" />
        <conv:BoolToStatusIconConverter x:Key="BoolToStatusIcon" />
        <conv:BoolToStatusBrushConverter x:Key="BoolToStatusBrush" />
        <conv:BoolToStatusBrushConverter x:Key="BoolToStatusBrushYellow" FalseBrushKey="YellowBrush" />
        <conv:BoolToStatusBrushConverter x:Key="BoolToStatusBrushSubtext" FalseBrushKey="SubtextBrush" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TextBlock.section-heading">
            <Setter Property="FontSize"   Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource SubtextBrush}" />
            <Setter Property="Margin"     Value="0,20,0,6" />
        </Style>

        <Style Selector="TextBlock.check-label">
            <Setter Property="Foreground"        Value="{DynamicResource TextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="RadioButton">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <Grid ColumnDefinitions="16,*"
                              ColumnSpacing="8">
                            <Grid Width="16"
                                  Height="16"
                                  VerticalAlignment="Center">
                                <Ellipse x:Name="OuterRing"
                                         Width="16"
                                         Height="16"
                                         Stroke="{DynamicResource TextBrush}"
                                         StrokeThickness="1.5"
                                         Fill="Transparent" />
                                <Ellipse x:Name="InnerDot"
                                         Width="8"
                                         Height="8"
                                         Fill="{DynamicResource AccentBrush}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         IsVisible="False" />
                            </Grid>
                            <ContentPresenter Grid.Column="1"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              VerticalAlignment="Center"
                                              Foreground="{TemplateBinding Foreground}" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="RadioButton:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource OverlayBrush}" />
        </Style>

        <Style Selector="RadioButton:pressed">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource OverlayBrush}" />
        </Style>

        <Style Selector="RadioButton /template/ ContentPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource TextBrush}" />
        </Style>

        <Style Selector="RadioButton:pointerover /template/ ContentPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource TextBrush}" />
        </Style>

        <Style Selector="RadioButton:pressed /template/ ContentPresenter">
            <Setter Property="TextElement.Foreground" Value="{DynamicResource TextBrush}" />
        </Style>

        <Style Selector="RadioButton:not(:checked) /template/ Ellipse#OuterRing">
            <Setter Property="Stroke" Value="{DynamicResource TextBrush}" />
        </Style>

        <Style Selector="RadioButton:checked /template/ Ellipse#OuterRing">
            <Setter Property="Stroke" Value="{DynamicResource AccentBrush}" />
        </Style>

        <Style Selector="RadioButton:checked /template/ Ellipse#InnerDot">
            <Setter Property="IsVisible" Value="True" />
        </Style>

        <Style Selector="RadioButton:not(:checked):pointerover /template/ Ellipse#OuterRing">
            <Setter Property="Stroke" Value="{DynamicResource TextBrush}" />
        </Style>

        <Style Selector="RadioButton:checked:pointerover /template/ Ellipse#OuterRing">
            <Setter Property="Stroke" Value="{DynamicResource AccentBrush}" />
        </Style>

        <Style Selector="Button.link-button">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="Foreground"      Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="4,2" />
        </Style>
    </Window.Styles>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Border Padding="24,12,38,32">
                <StackPanel MaxWidth="500">

                <!-- ─── Hardware & Performance ──────────────────────────────── -->
                <TextBlock x:Name="HardwareSectionHeader"
                           Text="{Binding Source={x:Static local:Loc.Instance}, Path=[settings_section_hardware]}"
                           Classes="section-heading" />

                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel>

                        <!-- Checking spinner (visible while running) -->
                        <TextBlock x:Name="HardwareCheckingText"
                                   Text="{Binding Source={x:Static local:Loc.Instance}, Path=[settings_hw_checking]}"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   Margin="0,0,0,8"
                                   IsVisible="{Binding IsCheckingHardware,
                                                        Converter={StaticResource BoolToVis}}" />

                        <!-- Hardware rows (hidden while checking) -->
                        <StackPanel IsVisible="{Binding IsCheckingHardware,
                                                         Converter={StaticResource InvBoolToVis}}">

                            <!-- NVIDIA GPU -->
                            <Grid Margin="0,0,0,6"
                                  IsVisible="{Binding GpuDetected, Converter={StaticResource BoolToVis}}"  >
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22" />
                                    <ColumnDefinition Width="*"  />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           Text="{Binding GpuDetected, Converter={StaticResource BoolToStatusIcon}}"
                                           Foreground="{Binding GpuDetected, Converter={StaticResource BoolToStatusBrushSubtext}}" />
                                <TextBlock Grid.Column="1" Text="NVIDIA GPU"
                                           Classes="check-label" />
                                <TextBlock Grid.Column="2" Text="{Binding GpuVramText}"
                                           Foreground="{DynamicResource SubtextBrush}"
                                           VerticalAlignment="Center" FontSize="12" />
                            </Grid>

                            <!-- CUDA checks — only shown when an NVIDIA GPU is present -->
                            <StackPanel IsVisible="{Binding GpuDetected,
                                                             Converter={StaticResource BoolToVis}}">

                                <!-- CUDA Toolkit -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22" />
                                        <ColumnDefinition Width="*"  />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               Text="{Binding CudaToolkitInstalled, Converter={StaticResource BoolToStatusIcon}}"
                                               Foreground="{Binding CudaToolkitInstalled, Converter={StaticResource BoolToStatusBrushYellow}}" />
                                    <TextBlock x:Name="CudaToolkitLabel"
                                               Grid.Column="1" Text="{Binding Source={x:Static local:Loc.Instance}, Path=[settings_hw_cuda_toolkit]}"
                                               Classes="check-label" />
                                    <Button x:Name="DownloadCudaButton"
                                            Grid.Column="2"
                                            Content="{Binding Source={x:Static local:Loc.Instance}, Path=[settings_hw_download_cuda]}"
                                            Classes="link-button"
                                            Command="{Binding OpenCudaDownloadPageCommand}"
                                            IsVisible="{Binding CudaToolkitInstalled,
                                                                 Converter={StaticResource InvBoolToVis}}" />
                                </Grid>

                                <!-- cuDNN -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22" />
                                        <ColumnDefinition Width="*"  />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               Text="{Binding CudnnInstalled, Converter={StaticResource BoolToStatusIcon}}"
                                               Foreground="{Binding CudnnInstalled, Converter={StaticResource BoolToStatusBrushYellow}}" />
                                    <TextBlock x:Name="CudnnLabel"
                                               Grid.Column="1" Text="{Binding Source={x:Static local:Loc.Instance}, Path=[settings_hw_cudnn]}"
                                               Classes="check-label" />
                                    <Button x:Name="DownloadCudnnButton"
                                            Grid.Column="2"
                                            Content="{Binding Source={x:Static local:Loc.Instance}, Path=[settings_hw_download_cudnn]}"
                                            Classes="link-button"
                                            Command="{Binding OpenCudnnDownloadPageCommand}"
                                            IsVisible="{Binding CudnnInstalled,
                                                                 Converter={StaticResource InvBoolToVis}}" />
                                </Grid>

                                <!-- CUDA EP active -->
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22" />
                                        <ColumnDefinition Width="*"  />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               Text="{Binding CudaEpWorking, Converter={StaticResource BoolToStatusIcon}}"
                                               Foreground="{Binding CudaEpWorking, Converter={StaticResource BoolToStatusBrushSubtext}}" />
                                    <TextBlock x:Name="CudaEpLabel"
                                               Grid.Column="1" Text="{Binding Source={x:Static local:Loc.Instance}, Path=[settings_hw_cuda_ep]}"
                                               Classes="check-label" />
                                </Grid>

                            </StackPanel>

                            <!-- No GPU message — shown when no acceleratable GPU is present -->
                            <TextBlock x:Name="NoGpuText"
                                       Text="{Binding Source={x:Static local:Loc.Instance}, Path=[settings_hw_no_gpu]}"
                                       Foreground="{DynamicResource SubtextBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"
                                       IsVisible="{Binding GpuDetected,
                                                            Converter={StaticResource InvBoolToVis}}" />

                            <!-- Batch ceiling -->
                            <TextBlock Text="{Binding BatchCeilingText}"
                                       Foreground="{DynamicResource SubtextBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12" />

                        </StackPanel>

                        <!-- Re-check button (always shown) -->
                        <Button x:Name="RecheckHardwareButton"
                                Content="{Binding Source={x:Static local:Loc.Instance}, Path=[settings_hw_recheck]}"
                                Classes="secondary-button"
                                Command="{Binding RecheckHardwareCommand}"
                                HorizontalAlignment="Left"
                                IsEnabled="{Binding IsCheckingHardware,
                                                    Converter={StaticResource InvBoolToVis}}" />
                    </StackPanel>
                </Border>

                <!-- ─── Models ───────────────────────────────────────────────── -->
                <TextBlock x:Name="ModelsSectionHeader"
                           Text="{Binding Source={x:Static local:Loc.Instance}, Path=[settings_section_models]}"
                           Classes="section-heading" />

                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel>

                        <!-- Model status -->
                        <TextBlock Text="{Binding ModelStatusText}"
                                   Foreground="{Binding ModelStatusBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10" />

                        <!-- Update / hash-check banner -->
                        <Border IsVisible="{Binding UpdateBannerVisible,
                                                     Converter={StaticResource BoolToVis}}"
                                Background="{DynamicResource OverlayBrush}"
                                CornerRadius="4"
                                Padding="10,8"
                                Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"    />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding UpdateBannerText}"
                                           Foreground="{DynamicResource TextBrush}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center" />
                                <Button Grid.Column="1"
                                        x:Name="UpdateModelsButton"
                                        Content="{Binding Source={x:Static local:Loc.Instance}, Path=[btn_update_models]}"
                                        Command="{Binding UpdateModelsCommand}"
                                        Margin="8,0,4,0"
                                        IsVisible="{Binding HasOutdatedFiles,
                                                             Converter={StaticResource BoolToVis}}" />
                                <Button Grid.Column="2"
                                        x:Name="DismissUpdateBannerButton"
                                        Content="{Binding Source={x:Static local:Loc.Instance}, Path=[btn_dismiss]}"
                                        Classes="secondary-button"
                                        Command="{Binding DismissUpdateBannerCommand}" />
                            </Grid>
                        </Border>

                        <!-- Download progress bar + status text -->
                        <StackPanel IsVisible="{Binding IsDownloading,
                                                         Converter={StaticResource BoolToVis}}"
                                    Margin="0,0,0,10">
                            <ProgressBar Value="{Binding DownloadPercent}"
                                         Minimum="0" Maximum="100"
                                         Margin="0,0,0,4" />
                            <TextBlock Text="{Binding DownloadStatusText}"
                                       Foreground="{DynamicResource SubtextBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <!-- Action buttons -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Button x:Name="DownloadModelsButton"
                                    Content="{Binding Source={x:Static local:Loc.Instance}, Path=[btn_download_models]}"
                                    Command="{Binding DownloadModelsCommand}"
                                    Margin="0,0,8,0"
                                    IsVisible="{Binding DownloadVisible,
                                                         Converter={StaticResource BoolToVis}}"
                                    IsEnabled="{Binding IsDownloading,
                                                        Converter={StaticResource InvBoolToVis}}" />
                            <Button x:Name="CancelDownloadButton"
                                    Content="{Binding Source={x:Static local:Loc.Instance}, Path=[btn_cancel]}"
                                    Classes="secondary-button"
                                    Command="{Binding CancelDownloadCommand}"
                                    Margin="0,0,8,0"
                                    IsVisible="{Binding IsDownloading,
                                                         Converter={StaticResource BoolToVis}}" />
                            <Button x:Name="CheckUpdatesButton"
                                    Content="{Binding Source={x:Static local:Loc.Instance}, Path=[btn_check_updates]}"
                                    Classes="secondary-button"
                                    Command="{Binding CheckForUpdatesCommand}"
                                    IsEnabled="{Binding IsCheckingUpdates,
                                                        Converter={StaticResource InvBoolToVis}}"
                                    IsVisible="{Binding ModelsReady,
                                                         Converter={StaticResource BoolToVis}}" />
                        </StackPanel>

                        <Separator Background="{DynamicResource OverlayBrush}" Margin="0,0,0,12" />
                        <TextBlock Text="Gated Models"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />
                        <TextBlock x:Name="GatedModelsStatusTextBlock"
                                   Text="{Binding GatedModelsStatusText}"
                                   Foreground="{DynamicResource SubtextBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8" />
                        <Button x:Name="OpenGatedModelsButton"
                                Content="Manage Gated Models"
                                Click="OpenGatedModels_Click"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,16" />

                    </StackPanel>
                </Border>

                <!-- ─── Speech Recognition ─────────────────────────────────── -->
                <TextBlock Text="Speech Recognition"
                           Classes="section-heading" />

                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel>

                        <RadioButton GroupName="AsrBackend"
                                     IsChecked="{Binding IsAsrParakeet, Mode=OneWay}"
                                     Command="{Binding SetAsrBackendCommand}"
                                     CommandParameter="Parakeet"
                                     Foreground="{DynamicResource TextBrush}"
                                     Margin="0,0,0,4">
                            <StackPanel>
                                <TextBlock Text="Parakeet"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock Text="Existing ONNX Parakeet backend. Best integrated option for now."
                                           Foreground="{DynamicResource SubtextBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </RadioButton>

                        <Separator Background="{DynamicResource OverlayBrush}" Margin="0,8,0,8" />

                        <RadioButton GroupName="AsrBackend"
                                     IsChecked="{Binding IsAsrCohere, Mode=OneWay}"
                                     Command="{Binding SetAsrBackendCommand}"
                                     CommandParameter="Cohere"
                                     Foreground="{DynamicResource TextBrush}">
                            <StackPanel>
                                <TextBlock Text="Cohere Transcribe"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock Text="Requires local Cohere weights in the cohere_transcribe models folder."
                                           Foreground="{DynamicResource SubtextBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </RadioButton>

                        <Separator Background="{DynamicResource OverlayBrush}" Margin="0,8,0,8" />

                        <RadioButton GroupName="AsrBackend"
                                     IsChecked="{Binding IsAsrVibeVoice, Mode=OneWay}"
                                     Command="{Binding SetAsrBackendCommand}"
                                     CommandParameter="VibeVoice"
                                     Foreground="{DynamicResource TextBrush}">
                            <StackPanel>
                                <TextBlock Text="VibeVoice-ASR"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock Text="Whole-recording ASR with built-in diarization. Requires local weights in the vibevoice_asr models folder."
                                           Foreground="{DynamicResource SubtextBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </RadioButton>

                        <StackPanel Margin="24,10,0,0"
                                    IsVisible="{Binding ShowCohereLanguagePicker}">
                            <TextBlock Text="Forced Language"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,6" />
                            <TextBlock Text="Optional. Use this when auto language detection is unstable."
                                       Foreground="{DynamicResource SubtextBrush}"
                                       FontSize="11"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8" />
                            <ComboBox ItemsSource="{x:Static vm:SettingsViewModel.CohereLanguages}"
                                      SelectedItem="{Binding SelectedCohereLanguage}"
                                      Background="{DynamicResource OverlayBrush}"
                                      Foreground="{DynamicResource TextBrush}"
                                      BorderBrush="{DynamicResource OverlayBrush}"
                                      HorizontalAlignment="Left"
                                      MinWidth="220">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                    </StackPanel>
                </Border>

                <!-- ─── Segmentation ────────────────────────────────────────── -->
                <TextBlock x:Name="SegmentationSectionHeader"
                           Text="{Binding Source={x:Static local:Loc.Instance}, Path=[settings_section_segmentation]}"
                           Classes="section-heading" />

                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel>

                        <!-- Silero VAD option -->
                        <RadioButton GroupName="Segmentation"
                                     IsChecked="{Binding IsSileroVad, Mode=OneWay}"
                                     Command="{Binding SetSegmentationCommand}"
                                     CommandParameter="SileroVad"
                                     Foreground="{DynamicResource TextBrush}"
                                     Margin="0,0,0,4"
                                     IsVisible="{Binding ShowStandardSegmentationOptions,
                                                         Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock x:Name="SegmentationSileroLabel"
                                           Text="{Binding Source={x:Static local:Loc.Instance}, Path=[settings_segmentation_vad]}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock x:Name="SegmentationSileroDescription"
                                           Text="{Binding Source={x:Static local:Loc.Instance}, Path=[settings_segmentation_vad_desc]}"
                                           Foreground="{DynamicResource SubtextBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </RadioButton>

                        <Separator Background="{DynamicResource OverlayBrush}" Margin="0,8,0,8"
                                   IsVisible="{Binding ShowStandardSegmentationOptions,
                                                       Converter={StaticResource BoolToVis}}" />

                        <!-- Sortformer option -->
                        <RadioButton GroupName="Segmentation"
                                     IsChecked="{Binding IsSortformer, Mode=OneWay}"
                                     Command="{Binding SetSegmentationCommand}"
                                     CommandParameter="Sortformer"
                                     Foreground="{DynamicResource TextBrush}"
                                     Margin="0,0,0,4"
                                     IsVisible="{Binding ShowStandardSegmentationOptions,
                                                         Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock x:Name="SegmentationSortformerLabel"
                                           Text="{Binding Source={x:Static local:Loc.Instance}, Path=[settings_segmentation_diarization]}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock x:Name="SegmentationSortformerDescription"
                                           Text="{Binding Source={x:Static local:Loc.Instance}, Path=[settings_segmentation_diarization_desc]}"
                                           Foreground="{DynamicResource SubtextBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </RadioButton>

                        <Separator Background="{DynamicResource OverlayBrush}" Margin="0,8,0,8"
                                   IsVisible="{Binding ShowStandardSegmentationOptions,
                                                       Converter={StaticResource BoolToVis}}" />

                        <TextBlock x:Name="GatedSegmentationHintText"
                                   Text="Additional gated segmentation models can be enabled from Models."
                                   Foreground="{DynamicResource SubtextBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,8"
                                   IsVisible="{Binding ShowGatedSegmentationHint,
                                                       Converter={StaticResource BoolToVis}}" />

                        <!-- DiariZen option -->
                        <RadioButton GroupName="Segmentation"
                                     IsChecked="{Binding IsDiariZen, Mode=OneWay}"
                                     Command="{Binding SetSegmentationCommand}"
                                     CommandParameter="DiariZen"
                                     Foreground="{DynamicResource TextBrush}"
                                     IsVisible="{Binding ShowDiariZenInSegmentation,
                                                         Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock x:Name="SegmentationDiariZenLabel"
                                           Text="{Binding Source={x:Static local:Loc.Instance}, Path=[settings_segmentation_diarizen]}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock x:Name="SegmentationDiariZenDescription"
                                           Text="{Binding Source={x:Static local:Loc.Instance}, Path=[settings_segmentation_diarizen_desc]}"
                                           Foreground="{DynamicResource SubtextBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </RadioButton>

                        <Separator Background="{DynamicResource OverlayBrush}" Margin="0,8,0,8"
                                   IsVisible="{Binding ShowStandardSegmentationOptions,
                                                       Converter={StaticResource BoolToVis}}" />

                        <!-- VibeVoice built-in diarization + ASR option -->
                        <RadioButton GroupName="Segmentation"
                                     IsChecked="{Binding IsVibeVoiceBuiltin, Mode=OneWay}"
                                     Command="{Binding SetSegmentationCommand}"
                                     CommandParameter="VibeVoiceBuiltin"
                                     Foreground="{DynamicResource TextBrush}"
                                     IsVisible="{Binding ShowVibeVoiceBuiltinSegmentation,
                                                         Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="VibeVoice-ASR (built-in)"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock Text="Whole-recording model with built-in diarization and ASR. Overrides the ASR backend selection. Requires weights in the vibevoice_asr models folder."
                                           Foreground="{DynamicResource SubtextBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </RadioButton>

                    </StackPanel>
                </Border>

                <!-- ─── Noise Reduction ───────────────────────────────────────── -->
                <TextBlock x:Name="DenoiserSectionHeader"
                           Text="{Binding Source={x:Static local:Loc.Instance}, Path=[settings_section_denoiser]}"
                           Classes="section-heading" />

                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel>

                        <!-- None option -->
                        <RadioButton GroupName="Denoiser"
                                     IsChecked="{Binding IsDenoiserNone, Mode=OneWay}"
                                     Command="{Binding SetDenoiserCommand}"
                                     CommandParameter="None"
                                     Foreground="{DynamicResource TextBrush}"
                                     Margin="0,0,0,4">
                            <StackPanel>
                                <TextBlock Text="{Binding Source={x:Static local:Loc.Instance}, Path=[settings_denoiser_none]}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock Text="{Binding Source={x:Static local:Loc.Instance}, Path=[settings_denoiser_none_desc]}"
                                           Foreground="{DynamicResource SubtextBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </RadioButton>

                        <Separator Background="{DynamicResource OverlayBrush}" Margin="0,8,0,8" />

                        <!-- DeepFilterNet3 option -->
                        <RadioButton GroupName="Denoiser"
                                     IsChecked="{Binding IsDenoiserDfn3, Mode=OneWay}"
                                     Command="{Binding SetDenoiserCommand}"
                                     CommandParameter="DeepFilterNet3"
                                     Foreground="{DynamicResource TextBrush}">
                            <StackPanel>
                                <TextBlock Text="{Binding Source={x:Static local:Loc.Instance}, Path=[settings_denoiser_dfn3]}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" />
                                <TextBlock Text="{Binding Source={x:Static local:Loc.Instance}, Path=[settings_denoiser_dfn3_desc]}"
                                           Foreground="{DynamicResource SubtextBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </RadioButton>

                    </StackPanel>
                </Border>

                <!-- ─── Transcript Editor ───────────────────────────────────── -->
                <TextBlock x:Name="EditorSectionHeader"
                           Text="{Binding Source={x:Static local:Loc.Instance}, Path=[settings_section_editor]}"
                           Classes="section-heading" />

                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock x:Name="EditorPlaybackModeLabel"
                                   Text="{Binding Source={x:Static local:Loc.Instance}, Path=[settings_editor_playback_mode]}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="EditorContinuousRadio"
                                         Content="{Binding Source={x:Static local:Loc.Instance}, Path=[editor_mode_continuous]}"
                                         Foreground="{DynamicResource TextBrush}"
                                         GroupName="EditorPlayback"
                                         IsChecked="{Binding IsEditorContinuous, Mode=OneWay}"
                                         Command="{Binding SetEditorPlaybackModeCommand}"
                                         CommandParameter="Continuous"
                                         Margin="0,0,20,0" />
                            <RadioButton x:Name="EditorSingleRadio"
                                         Content="{Binding Source={x:Static local:Loc.Instance}, Path=[editor_mode_single]}"
                                         Foreground="{DynamicResource TextBrush}"
                                         GroupName="EditorPlayback"
                                         IsChecked="{Binding IsEditorSingle, Mode=OneWay}"
                                         Command="{Binding SetEditorPlaybackModeCommand}"
                                         CommandParameter="Single"
                                         Margin="0,0,20,0" />
                            <RadioButton x:Name="EditorAutoAdvanceRadio"
                                         Content="{Binding Source={x:Static local:Loc.Instance}, Path=[editor_auto_advance]}"
                                         Foreground="{DynamicResource TextBrush}"
                                         GroupName="EditorPlayback"
                                         IsChecked="{Binding IsEditorAutoAdvance, Mode=OneWay}"
                                         Command="{Binding SetEditorPlaybackModeCommand}"
                                         CommandParameter="AutoAdvance" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ─── Appearance ───────────────────────────────────────────── -->
                <TextBlock x:Name="AppearanceSectionHeader"
                           Text="{Binding Source={x:Static local:Loc.Instance}, Path=[settings_section_appearance]}"
                           Classes="section-heading" />

                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock x:Name="ThemeLabel"
                                   Text="{Binding Source={x:Static local:Loc.Instance}, Path=[menu_theme]}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="ThemeDarkRadio"
                                         Content="{Binding Source={x:Static local:Loc.Instance}, Path=[menu_theme_dark]}"
                                         Foreground="{DynamicResource TextBrush}"
                                         GroupName="Theme"
                                         IsChecked="{Binding IsDark, Mode=OneWay}"
                                         Command="{Binding SetThemeCommand}"
                                         CommandParameter="Dark"
                                         Margin="0,0,20,0" />
                            <RadioButton x:Name="ThemeLightRadio"
                                         Content="{Binding Source={x:Static local:Loc.Instance}, Path=[menu_theme_light]}"
                                         Foreground="{DynamicResource TextBrush}"
                                         GroupName="Theme"
                                         IsChecked="{Binding IsLight, Mode=OneWay}"
                                         Command="{Binding SetThemeCommand}"
                                         CommandParameter="Light" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ─── Language ─────────────────────────────────────────────── -->
                <TextBlock x:Name="LanguageSectionHeader"
                           Text="{Binding Source={x:Static local:Loc.Instance}, Path=[settings_section_language]}"
                           Classes="section-heading" />

                <Border Background="{DynamicResource SurfaceBrush}"
                        CornerRadius="8" Padding="16"
                        Margin="0,0,0,16">
                    <ComboBox ItemsSource="{x:Static local:Loc.Languages}"
                              SelectedItem="{Binding SelectedLanguageInfo}"
                              Background="{DynamicResource OverlayBrush}"
                              Foreground="{DynamicResource TextBrush}"
                              BorderBrush="{DynamicResource OverlayBrush}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Border>

                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- ─── Footer ───────────────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource OverlayBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Button x:Name="OkButton"
                    Content="{Binding Source={x:Static local:Loc.Instance}, Path=[btn_ok]}"
                    Classes="secondary-button"
                    HorizontalAlignment="Right"
                    Click="Close_Click" />
        </Border>
    </Grid>
</Window>
