<Window x:Class="Vernacula.App.Views.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Vernacula.App.ViewModels"
        xmlns:v="using:Vernacula.App.Views"
        xmlns:local="using:Vernacula.App"
        x:DataType="vm:MainViewModel"
        Title="Parakeet Transcription"
        Icon="avares://Vernacula.Avalonia/Assets/icon.ico"
        Width="920" Height="840"
        MinWidth="700" MinHeight="500"
        Background="{DynamicResource BgBrush}"
        SystemDecorations="Full">

    <Window.DataTemplates>
        <DataTemplate DataType="vm:HomeViewModel">
            <v:HomeView />
        </DataTemplate>
        <DataTemplate DataType="vm:ProgressViewModel">
            <v:ProgressView />
        </DataTemplate>
        <DataTemplate DataType="vm:ResultsViewModel">
            <v:ResultsView />
        </DataTemplate>
    </Window.DataTemplates>

    <DockPanel>
        <!-- ── Menu bar ── -->
        <Menu DockPanel.Dock="Top">
            <MenuItem x:Name="FileMenuItem" Header="{local:Loc menu_file}">
                <MenuItem x:Name="NewTranscriptionMenuItem" Header="{local:Loc menu_new_transcription}"
                          Command="{Binding Home.NewTranscriptionCommand}" />
                <Separator />
                <MenuItem x:Name="ExitMenuItem" Header="{local:Loc menu_exit}" Click="Exit_Click" />
            </MenuItem>

            <MenuItem x:Name="SettingsMenuItem" Header="{local:Loc menu_settings}"
                      Click="Settings_Click" />

            <MenuItem x:Name="HelpMenuItem" Header="{local:Loc menu_help}">
                <MenuItem x:Name="HelpContentsMenuItem" Header="{local:Loc menu_help_contents}" Click="HelpContents_Click" />
                <Separator />
                <MenuItem x:Name="AboutMenuItem" Header="{local:Loc menu_about}" Click="About_Click" />
            </MenuItem>
        </Menu>

        <!-- ── Panel content ── -->
        <ContentControl Content="{Binding CurrentPanelViewModel}"
                        Margin="16" />
    </DockPanel>
</Window>
