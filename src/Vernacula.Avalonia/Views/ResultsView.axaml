<UserControl x:Class="Vernacula.App.Views.ResultsView"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Vernacula.App"
             xmlns:conv="using:Vernacula.App.Converters"
             xmlns:vm="using:Vernacula.App.ViewModels"
             x:DataType="vm:ResultsViewModel"
             Focusable="True"
             KeyDown="ResultsView_KeyDown"
             PointerPressed="ResultsView_PointerPressed">

    <UserControl.Resources>
        <conv:SecondsToTimeConverter x:Key="SecondsToTime" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Audio file name -->
            <RowDefinition Height="Auto" />   <!-- Segment count -->
            <RowDefinition Height="Auto" />   <!-- LID info chip (happy path) -->
            <RowDefinition Height="Auto" />   <!-- LID mismatch banner -->
            <RowDefinition Height="*"    />   <!-- Segments table -->
            <RowDefinition Height="Auto" />   <!-- Action buttons -->
        </Grid.RowDefinitions>

        <!-- Header: audio file name -->
        <TextBlock Grid.Row="0"
                   Foreground="{DynamicResource TextBrush}"
                   Text="{Binding AudioBaseName}"
                   FontSize="20" FontWeight="SemiBold"
                   Margin="0,0,0,4" />

        <!-- Segment count subtitle -->
        <TextBlock Grid.Row="1"
                   Foreground="{DynamicResource SubtextBrush}"
                   Margin="0,0,0,8">
            <Run Text="{Binding Segments.Count, Mode=OneWay}" />
            <Run x:Name="SegmentsLabelRun" Text="{local:Loc results_segments_label}" />
        </TextBlock>

        <!-- LID info chip (neutral info shown on every LID-enabled job) -->
        <Border Grid.Row="2"
                IsVisible="{Binding ShowDetectedLanguageInfo}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource OverlayBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8,4"
                HorizontalAlignment="Left"
                Margin="0,0,0,8">
            <TextBlock Text="{Binding DetectedLanguageInfoText}"
                       Foreground="{DynamicResource SubtextBrush}"
                       FontSize="11" />
        </Border>

        <!-- LID mismatch banner -->
        <Border Grid.Row="3"
                IsVisible="{Binding ShowMismatchBanner}"
                Background="#3A2A1A"
                BorderBrush="#C8A040"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12"
                Margin="0,0,0,12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="Possible language mismatch"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}" />
                    <TextBlock Text="{Binding MismatchBannerText}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextBrush}" />
                </StackPanel>
                <Button Grid.Column="1"
                        VerticalAlignment="Center"
                        Content="{Binding ReprocessButtonText}"
                        Command="{Binding ReprocessWithSuggestedBackendCommand}"
                        IsEnabled="{Binding CanReprocess}" />
            </Grid>
        </Border>

        <!-- User-forced language badge (supersedes the mismatch banner when
             the user explicitly chose to transcribe as a related language). -->
        <Border Grid.Row="3"
                IsVisible="{Binding ShowUserForcedLanguageBadge}"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource OverlayBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8,4"
                HorizontalAlignment="Left"
                Margin="0,0,0,12">
            <TextBlock Text="{Binding UserForcedLanguageBadgeText}"
                       Foreground="{DynamicResource SubtextBrush}"
                       FontSize="11" />
        </Border>

        <!-- Segments table -->
        <DataGrid x:Name="SegmentsGrid"
                  Grid.Row="4"
                  Margin="0,0,0,12"
                  ItemsSource="{Binding Segments}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserReorderColumns="False"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding SpeakerDisplayName}" Width="110">
                    <DataGridTextColumn.Header>
                        <TextBlock Text="{Binding Source={x:Static local:Loc.Instance}, Path=[segments_col_speaker]}" />
                    </DataGridTextColumn.Header>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="{Binding Source={x:Static local:Loc.Instance}, Path=[segments_col_start]}"
                                        Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StartTime, Converter={StaticResource SecondsToTime}}"
                                       Padding="4,2"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="{Binding Source={x:Static local:Loc.Instance}, Path=[segments_col_end]}"
                                        Width="70">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding EndTime, Converter={StaticResource SecondsToTime}}"
                                       Padding="4,2"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="*">
                    <DataGridTemplateColumn.Header>
                        <TextBlock Text="{Binding Source={x:Static local:Loc.Instance}, Path=[segments_col_content]}" />
                    </DataGridTemplateColumn.Header>
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}"
                                       TextWrapping="Wrap"
                                       Padding="4,2"
                                       VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Action buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="EditTranscriptButton" Content="{local:Loc btn_edit_transcript}"
                    Classes="secondary-button"
                    Command="{Binding EditTranscriptCommand}"
                    Margin="0,0,8,0" />
            <Button x:Name="EditSpeakersButton" Content="{local:Loc btn_edit_speakers}"
                    Classes="secondary-button"
                    Command="{Binding EditSpeakerNamesCommand}"
                    Margin="0,0,8,0" />
            <Button x:Name="ExportButton" Content="{local:Loc btn_export}"
                    Command="{Binding ExportCommand}"
                    Margin="0,0,8,0" />
            <Button x:Name="BackHistoryButton" Content="{local:Loc btn_back_history}"
                    Classes="secondary-button"
                    Command="{Binding BackCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
